{{- $repo := "open-stage/blender-dmx" -}}
{{- $release := dict -}}
{{- with resources.GetRemote (printf "https://api.github.com/repos/%s/releases/latest" $repo) -}}
  {{- $release = . | transform.Unmarshal -}}
{{- end -}}
{{- $asset := dict -}}
{{- if and $release (isset $release "assets") (gt (len $release.assets) 0) -}}
  {{- $asset = index $release.assets 0 -}}
{{- end -}}
{{- $version := "0.0.0" -}}
{{- if and $release (isset $release "tag_name") -}}
  {{- $version = replaceRE "^v" "" $release.tag_name -}}
{{- end -}}
{{- $archiveURL := printf "https://github.com/%s/releases/latest" $repo -}}
{{- if and $asset (isset $asset "browser_download_url") -}}
  {{- $archiveURL = $asset.browser_download_url -}}
{{- end -}}
{{- $digest := "" -}}
{{- if and $asset (isset $asset "digest") -}}
  {{- $digest = $asset.digest -}}
{{- end -}}
{{- $archiveName := "" -}}
{{- if and $asset (isset $asset "name") -}}
  {{- $archiveName = $asset.name -}}
{{- end -}}
{{- dict
  "version" "v1"
  "blocklist" (slice)
  "data" (slice (dict
    "schema_version" "1.0.0"
    "id" "open_stage_blender_dmx"
    "name" "DMX"
    "tagline" "Visualization & programming with GDTF&MVR, OSC, PSN, Networking"
    "version" $version
    "type" "add-on"
    "maintainer" "Open Stage"
    "license" (slice "SPDX:GPL-3.0-or-later")
    "blender_version_min" "4.2.0"
    "website" "https://blenderdmx.eu/"
    "copyright" (slice "2021 Open Stage")
    "permissions" (dict
      "files" "Import GDTF devices. Import/Export MVR scenes and project data"
      "network" "For GDTF Share, sACN, Art-Net, OSC, PSN, MVR-xchange"
    )
    "python_versions" (slice "3")
    "archive_url" $archiveURL
    "archive_size" (cond (and $asset (isset $asset "size")) $asset.size 0)
    "archive_hash" $digest
  ))
| jsonify -}}
